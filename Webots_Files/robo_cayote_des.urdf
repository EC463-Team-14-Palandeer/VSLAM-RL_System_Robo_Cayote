<?xml version="1.0"?>
<robot name="robo_cayote">

  <link name="base_link">
    <visual><origin xyz="0 0.14 0"/><geometry><box size="0.84 0.06 0.4359"/></geometry></visual>
    <collision><origin xyz="0 0.14 0"/><geometry><box size="0.84 0.06 0.4359"/></geometry></collision>
    <inertial><mass value="5.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial>
  </link>

  <joint name="slider_fr" type="prismatic">
    <parent link="base_link"/><child link="solid"/><axis xyz="0 1 0"/>
    <limit lower="-0.1" upper="0.1" effort="10" velocity="10"/>
    <origin xyz="0.31 0.02 -0.28"/>
  </joint>
  <link name="solid">
    <visual><geometry><box size="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="steer_motor_fr" type="continuous">
    <parent link="solid"/><child link="solid_0"/><axis xyz="0 1 0"/>
    <origin xyz="0 0 0"/>
  </joint>
  <link name="solid_0">
    <visual><geometry><box size="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="wheel_motor_fr" type="continuous">
    <parent link="solid_0"/><child link="solid_1"/><axis xyz="0 0 1"/>
    <origin xyz="0 0 0"/>
  </joint>
  <link name="solid_1">
    <visual><geometry><cylinder radius="0.06" length="0.05"/></geometry></visual>
    <collision><geometry><cylinder radius="0.06" length="0.05"/></geometry></collision>
    <inertial><mass value="0.5"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <joint name="slider_fl" type="prismatic">
    <parent link="base_link"/><child link="solid_3"/><axis xyz="0 1 0"/>
    <limit lower="-0.1" upper="0.1" effort="10" velocity="10"/>
    <origin xyz="0.31 0.02 0.28"/>
  </joint>
  <link name="solid_3">
    <visual><geometry><box size="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="steer_motor_fl" type="continuous">
    <parent link="solid_3"/><child link="solid_4"/><axis xyz="0 1 0"/>
  </joint>
  <link name="solid_4">
    <visual><geometry><box size="0.001 0.001 0.001"/></geometry></visual>
    <inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="wheel_motor_fl" type="continuous">
    <parent link="solid_4"/><child link="solid_5"/><axis xyz="0 0 1"/>
  </joint>
  <link name="solid_5">
    <visual><geometry><cylinder radius="0.06" length="0.05"/></geometry></visual>
    <collision><geometry><cylinder radius="0.06" length="0.05"/></geometry></collision>
    <inertial><mass value="0.5"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>

  <link name="gps"><visual><geometry><box size="0.001 0.001 0.001"/></geometry></visual><inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <joint name="base_gps" type="fixed"><parent link="base_link"/><child link="gps"/><origin xyz="0 0 0"/></joint>

  <link name="imu"><visual><geometry><box size="0.001 0.001 0.001"/></geometry></visual><inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <joint name="base_imu" type="fixed"><parent link="base_link"/><child link="imu"/><origin xyz="0 0 0"/></joint>

</robot>
